[
    {
        "doctype": "Custom Field",
        "name": "LMS Program-description",
        "dt": "LMS Program",
        "label": "Description",
        "fieldname": "description",
        "fieldtype": "Text Editor",
        "insert_after": "title",
        "reqd": 0,
        "hidden": 0
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-programs",
        "dt": "LMS Settings",
        "label": "Programs",
        "fieldname": "programs",
        "fieldtype": "Check",
        "default": "1",
        "insert_after": "courses"
    },
    {
        "doctype": "Custom Field",
        "name": "Course Lesson-duration",
        "dt": "Course Lesson",
        "fieldname": "duration",
        "fieldtype": "Data",
        "in_list_view": 1,
        "label": "Duration",
        "reqd": 0
    },
    {
        "doctype": "Custom Field",
        "name": "Course Index-status",
        "dt": "Course Lesson",
        "fieldname": "index_status",
        "fieldtype": "Select",
        "in_list_view": 1,
        "label": "Index Status",
        "reqd": 0,
        "options": "pending\nindexed\nfailed\nprocessing"
    },
    {
        "doctype": "Custom Field",
        "name": "Course Lesson-indexed_at",
        "dt": "Course Lesson",
        "fieldname": "indexed_at",
        "fieldtype": "Datetime",
        "in_list_view": 1,
        "label": "Indexed At",
        "reqd": 0
    },
    {
        "doctype": "Custom Field",
        "name": "Course Lesson-tags",
        "dt": "Course Lesson",
        "fieldname": "tags",
        "fieldtype": "Small Text",
        "label": "Tags",
        "reqd": 0,
        "insert_after": "title"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-home",
        "dt": "LMS Settings",
        "label": "Home",
        "fieldname": "home",
        "fieldtype": "Check",
        "default": "1",
        "insert_after": "items_in_sidebar_section"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-search",
        "dt": "LMS Settings",
        "label": "Search",
        "fieldname": "search",
        "fieldtype": "Check",
        "default": "1",
        "insert_after": "notifications"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-quizzes",
        "dt": "LMS Settings",
        "label": "Quizzes",
        "fieldname": "quizzes",
        "fieldtype": "Check",
        "default": "1",
        "insert_after": "search"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-assignments",
        "dt": "LMS Settings",
        "label": "Assignments",
        "fieldname": "assignments",
        "fieldtype": "Check",
        "default": "1",
        "insert_after": "quizzes"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Batch-custom_feature_sections",
