        "depends_on": "eval:doc.hero_enabled"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Course-hero_media_url",
        "dt": "LMS Course",
        "label": "Hero Media URL",
        "fieldname": "hero_media_url",
        "fieldtype": "Data",
        "insert_after": "hero_media_type",
        "depends_on": "eval:doc.hero_enabled"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Course-trueskills_certificate_enabled",
