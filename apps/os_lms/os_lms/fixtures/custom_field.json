        "fieldname": "trueskills_certificate_enabled",
        "fieldtype": "Check",
        "default": "0",
        "insert_after": "enable_certification"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Course-trueskills_template_id",
        "dt": "LMS Course",
        "label": "TrueSkills Template",
        "fieldname": "trueskills_template_id",
        "fieldtype": "Data",
        "insert_after": "trueskills_certificate_enabled",
        "depends_on": "eval:doc.trueskills_certificate_enabled"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-trueskills_api_enabled",
        "dt": "LMS Settings",
        "label": "Enable TrueSkills API",
        "fieldname": "trueskills_api_enabled",
        "fieldtype": "Check",
        "default": "0",
        "insert_after": "livecode_url"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-trueskills_api_key",
        "dt": "LMS Settings",
        "label": "TrueSkills API Key",
        "fieldname": "trueskills_api_key",
        "fieldtype": "Password",
        "insert_after": "trueskills_api_enabled"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-trueskills_api_endpoint",
        "dt": "LMS Settings",
        "label": "TrueSkills API Endpoint",
        "fieldname": "trueskills_api_endpoint",
        "fieldtype": "Data",
        "insert_after": "trueskills_api_key"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-welcome_video_section",
        "dt": "LMS Settings",
        "label": "Welcome Video",
        "fieldname": "welcome_video_section",
        "fieldtype": "Section Break",
        "insert_after": "trueskills_api_endpoint",
        "collapsible": 1
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-welcome_video_enabled",
        "dt": "LMS Settings",
        "label": "Enable Welcome Video",
        "fieldname": "welcome_video_enabled",
        "fieldtype": "Check",
        "default": "0",
        "insert_after": "welcome_video_section"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-welcome_video_title",
        "dt": "LMS Settings",
        "label": "Welcome Video Title",
        "fieldname": "welcome_video_title",
        "fieldtype": "Data",
        "insert_after": "welcome_video_enabled",
        "depends_on": "eval:doc.welcome_video_enabled"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-welcome_video_subtitle",
        "dt": "LMS Settings",
        "label": "Welcome Video Subtitle",
        "fieldname": "welcome_video_subtitle",
        "fieldtype": "Data",
        "insert_after": "welcome_video_title",
        "depends_on": "eval:doc.welcome_video_enabled"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Settings-welcome_video_file",
        "dt": "LMS Settings",
        "label": "Welcome Video (URL or file path)",
        "fieldname": "welcome_video_file",
        "fieldtype": "Data",
        "insert_after": "welcome_video_subtitle",
        "depends_on": "eval:doc.welcome_video_enabled",
        "description": "Paste a video URL (YouTube, Vimeo, etc.) or pick a file path. URLs are rendered as iframe embeds; paths as native <video>."
    },
    {
        "doctype": "Custom Field",
        "name": "User-welcome_video_seen",
        "dt": "User",
        "label": "Welcome Video Seen",
        "fieldname": "welcome_video_seen",
        "fieldtype": "Check",
        "default": "0",
        "insert_after": "bio",
        "hidden": 1,
        "no_copy": 1,
        "read_only": 1
    },
    {
        "doctype": "Custom Field",
        "name": "User-first_login",
        "dt": "User",
        "label": "First Login",
        "fieldname": "first_login",
        "fieldtype": "Check",
        "default": "0",
        "insert_after": "welcome_video_seen",
        "hidden": 1,
        "no_copy": 1,
        "read_only": 1
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Live Class-reminders_section",
        "dt": "LMS Live Class",
