        "fieldtype": "Check",
        "default": "0",
        "insert_after": "disable_self_learning"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Course-enforce_quiz_on_completion",
        "dt": "LMS Course",
        "label": "Enforce Quiz on Completion",
        "fieldname": "enforce_quiz_on_completion",
        "fieldtype": "Check",
        "default": "0",
        "insert_after": "enforce_lesson_order"
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Course-hero_enabled",
        "dt": "LMS Course",
