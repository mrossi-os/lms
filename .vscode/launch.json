{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Frappe Web: Attach Remoto",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "/workspace"
        },
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "/home/frappe/bench-data/frappe-bench/apps/lms"
        }
      ],
      "justMyCode": false
    }
  ]
}