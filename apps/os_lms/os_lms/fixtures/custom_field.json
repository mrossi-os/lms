        "insert_after": "description",
        "collapsible": 1
    },
    {
        "doctype": "Custom Field",
        "name": "LMS Live Class-reminders",
        "dt": "LMS Live Class",
        "label": "Reminders",
        "fieldname": "reminders",
        "fieldtype": "Table",
        "options": "LMS Live Class Reminder",
        "insert_after": "reminders_section"
